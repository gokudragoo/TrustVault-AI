# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Backend
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATA_DIR=./data
ENCRYPTION_MASTER_KEY=replace-with-32-byte-random-secret
VAULT_ACCESS_KEY=replace-with-owner-login-secret
AUTH_TOKEN_TTL_HOURS=12

# Terminal3 ADK
T3N_ENVIRONMENT=testnet
T3N_API_KEY=replace-with-terminal3-sandbox-api-key
T3N_DID=did:t3n:replace-with-your-did

# AI
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-5.5

# Optional persistence and media
MONGODB_URI=mongodb+srv://user:pass@cluster/database
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
